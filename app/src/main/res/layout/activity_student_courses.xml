<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".StudentCourses">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="12dp">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="60dp"

            app:cardCornerRadius="14dp"
            app:cardElevation="6dp"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:id="@+id/btnBackDashboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#1E88E5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back to Dashboard"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Courses"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:layout_marginBottom="12dp"/>

        <!-- SEARCH BAR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@color/white"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#1E88E5"/>

                <AutoCompleteTextView
                    android:id="@+id/edtSearchCourse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Search course..."
                    android:background="@null"
                    android:paddingStart="10dp"
                    android:textSize="16sp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- SEARCH RESULT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSearchResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtCourseName"
                    android:text="Course Name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtCourseCode"
                    android:text="Code: CSC101"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtCourseLecturer"
                    android:text="Lecturer: John Doe"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/txtCourseVenue"
                    android:text="Venue: Block A"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>

                <!-- ENROLL BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enroll"
                    android:layout_marginTop="12dp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#1E88E5"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ENROLLED SECTION TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enrolled Courses"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E88E5"
            android:layout_marginBottom="10dp"/>

        <!-- ENROLLED COURSES LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEnrolledCourses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

</ScrollView>