<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".LecturerDashboard">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical">
    <!-- top card with deatils  -->
        <com.google.android.material.card.MaterialCardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">
                <!-- USER CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/white"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/txtName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#000000"/>

                        <TextView
                            android:id="@+id/txtStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Active Lecturer"
                            android:textSize="16sp"
                            android:layout_marginTop="6dp"
                            android:textColor="#1E88E5"/>
                        <TextView
                            android:id="@+id/txtEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="lec@gmail.com"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1E88E5"
                            android:paddingBottom="12dp"/>
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- BUTTON GRID CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="6dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:background="@color/white"
                        android:padding="10dp">

                        <!-- My Courses -->
                        <Button
                            android:id="@+id/btnMyCourses"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="My Courses"
                            android:backgroundTint="#1E88E5"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>

                        <!-- Red Flags -->
                        <Button
                            android:id="@+id/btnRedFlags"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="Red Flags"
                            android:backgroundTint="#FF5722"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>

                        <!-- Reports -->
                        <Button
                            android:id="@+id/btnReport"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="Reports"
                            android:backgroundTint="#1E88E5"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>

                        <!-- Logout -->
                        <Button
                            android:id="@+id/btnLogout"
                            android:layout_width="0dp"
                            android:layout_height="60dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:text="Logout"
                            android:backgroundTint="#D32F2F"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>

                    </GridLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
    <!-- end of top card  -->
        <com.google.android.material.card.MaterialCardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📡 Open Session"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5"
                    android:layout_marginBottom="12dp"/>

                <!-- COURSE -->
                <Spinner
                    android:id="@+id/spinnerCourse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- DATE (CLICK ONLY FIELD) -->
                <TextView
                    android:id="@+id/edtDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Date"
                    android:textSize="16sp"
                    android:padding="14dp"
                    android:layout_marginTop="10dp"
                    android:background="#EEEEEE"
                    android:textColor="#000000"/>

                <!-- TIME (CLICK ONLY FIELD) -->
                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Time"
                    android:textSize="16sp"
                    android:padding="14dp"
                    android:layout_marginTop="10dp"
                    android:background="#EEEEEE"
                    android:textColor="#000000"/>

                <!-- DURATION -->
                <Spinner
                    android:id="@+id/spinnerDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"/>

                <!-- OPEN BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenSession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Open Session"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#1E88E5"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
    <!-- -->

        <com.google.android.material.card.MaterialCardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Marked Attendance (Active Session)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5"
                    android:layout_marginBottom="10dp"/>

                <!-- SESSION STATUS -->
                <TextView
                    android:id="@+id/txtSessionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: LIVE"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginBottom="6dp"/>

                <!-- ATTENDANCE COUNT -->
                <TextView
                    android:id="@+id/txtAttendanceCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Present: 0"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="10dp"/>

                <!-- RECYCLER VIEW -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerMarkedAttendance"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:padding="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
    <!-- -->
    <!-- -->
    <!-- -->
    <!-- -->
    <!-- -->
    <!-- -->
    <!-- -->
    </LinearLayout>
</ScrollView>